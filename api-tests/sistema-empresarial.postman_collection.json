{
  "info": {
    "name": "Sistema Empresarial vFinal - Pruebas Automatizadas",
    "_postman_id": "final-2026-03-30-001",
    "description": "Suite de pruebas automatizada con dependencias entre módulos y limpieza final.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:3000"},
    {"key": "timestamp", "value": "{{$timestamp}}"},
    {"key": "mongoUserId", "value": ""},
    {"key": "mysqlUserId", "value": ""}
  ],
  "item": [
    {
      "name": "Usuarios Dinámicos",
      "item": [
        {
          "name": "Crear usuario MongoDB",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body":{"mode":"raw","raw":"{\n  \"nombre\": \"Juan_{{$timestamp}}\",\n  \"email\": \"juan{{$timestamp}}@example.com\",\n  \"password\": \"123456\"\n}"},
            "url":{"raw":"{{baseUrl}}/api/mongo-users"}
          },
          "event":[
            {
              "listen":"test",
              "script":{"exec":[
                "pm.test(\"Status code 201\", () => pm.response.to.have.status(201));",
                "pm.environment.set('mongoUserId', pm.response.json()._id);"
              ]}
            }
          ]
        },
        {
          "name": "Crear usuario MySQL",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body":{"mode":"raw","raw":"{\n  \"nombre\": \"Ana_{{$timestamp}}\",\n  \"email\": \"ana{{$timestamp}}@example.com\",\n  \"password\": \"123456\"\n}"},
            "url":{"raw":"{{baseUrl}}/api/mysql-users"}
          },
          "event":[
            {
              "listen":"test",
              "script":{"exec":[
                "pm.test(\"Status code 201\", () => pm.response.to.have.status(201));",
                "pm.environment.set('mysqlUserId', pm.response.json().id);"
              ]}
            }
          ]
        }
      ]
    },
    {
      "name": "Módulos Empresariales Dependientes",
      "item": [
        {
          "name": "Crear venta asociada a usuario MongoDB",
          "request": {
            "method": "POST",
            "header": [{"key":"Content-Type","value":"application/json"}],
            "body":{"mode":"raw","raw":"{\n  \"usuarioId\": \"{{mongoUserId}}\",\n  \"producto\": \"Producto Test\",\n  \"cantidad\": 1,\n  \"total\": 100\n}"},
            "url":{"raw":"{{baseUrl}}/api/ventas"}
          },
          "event":[
            {"listen":"test","script":{"exec":["pm.test('Venta creada', () => pm.response.to.have.status(201));"]}}
          ]
        },
        {
          "name": "Listar Ventas",
          "request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/ventas"},"header":[{"key":"Content-Type","value":"application/json"}]},
          "event":[{"listen":"test","script":{"exec":["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Listar Productos",
          "request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/productos"},"header":[{"key":"Content-Type","value":"application/json"}]},
          "event":[{"listen":"test","script":{"exec":["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Listar Clientes",
          "request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/clientes"},"header":[{"key":"Content-Type","value":"application/json"}]},
          "event":[{"listen":"test","script":{"exec":["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        },
        {
          "name": "Reportes - Ventas",
          "request":{"method":"GET","url":{"raw":"{{baseUrl}}/api/reportes/ventas?fecha_inicio=2026-01-01&fecha_fin=2026-03-30"},"header":[{"key":"Content-Type","value":"application/json"}]},
          "event":[{"listen":"test","script":{"exec":["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}]
        }
      ]
    },
    {
      "name": "Eliminar Usuarios (Cleanup)",
      "item":[
        {
          "name": "Eliminar usuario MongoDB",
          "request":{"method":"DELETE","url":{"raw":"{{baseUrl}}/api/mongo-users/:id"},"header":[{"key":"Content-Type","value":"application/json"}]},
          "event":[
            {"listen":"prerequest","script":{"exec":["pm.request.url.path[2] = pm.environment.get('mongoUserId');"]}},
            {"listen":"test","script":{"exec":["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}
          ]
        },
        {
          "name": "Eliminar usuario MySQL",
          "request":{"method":"DELETE","url":{"raw":"{{baseUrl}}/api/mysql-users/:id"},"header":[{"key":"Content-Type","value":"application/json"}]},
          "event":[
            {"listen":"prerequest","script":{"exec":["pm.request.url.path[2] = pm.environment.get('mysqlUserId');"]}},
            {"listen":"test","script":{"exec":["pm.test('Status 200', () => pm.response.to.have.status(200));"]}}
          ]
        }
      ]
    }
  ]
}